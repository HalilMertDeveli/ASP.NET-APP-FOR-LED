@model IEnumerable<Web.HMD.Models.ASeriesSpecViewModel>

@{
    ViewData["Title"] = "A Serisi Ana Kart Teknik Ozellikleri";
}

<section class="py-3">
    <div class="mb-4">
        <h1 class="h3 fw-bold">A Serisi Ana Kart Teknik Ozellikleri</h1>
        <p class="text-muted mb-0">Her model tek tek satisa uygundur. Asagida model, port ve maksimum cozunurluk bilgileri yer alir.</p>
    </div>

    <div class="table-responsive mb-4">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Model</th>
                    <th>Port</th>
                    <th>Maksimum Cozunurluk</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><strong>@item.Model</strong></td>
                        <td>@item.Port</td>
                        <td>@item.MaxResolution</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="row g-3">
        @foreach (var item in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <h5 class="mb-2">@item.Model</h5>
                        <p class="mb-1"><strong>Port:</strong> @item.Port</p>
                        <p class="mb-0"><strong>Max:</strong> @item.MaxResolution</p>
                    </div>
                </div>
            </div>
        }
    </div>
</section>
