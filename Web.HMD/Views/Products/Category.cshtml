@model Web.HMD.Models.ProductCategoryViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="product-category-page py-3">
    <div class="row g-4 align-items-center">
        <div class="col-lg-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded-4 shadow-sm" alt="@Model.Title" />
        </div>
        <div class="col-lg-6">
            <h1 class="h2 fw-bold mb-2">@Model.Title</h1>
            <p class="text-muted mb-3">@Model.Subtitle</p>
            <p>@Model.Description</p>

            <div class="card border-0 shadow-sm mt-3">
                <div class="card-body">
                    <h5 class="mb-2">Temel Ozellikler</h5>
                    <ul class="mb-0">
                        @foreach (var feature in Model.KeyFeatures)
                        {
                            <li>@feature</li>
                        }
                    </ul>
                </div>
            </div>

            <div class="mt-3 d-flex gap-2 flex-wrap">
                <a asp-controller="Home" asp-action="CartStatus" class="btn btn-outline-primary">Sepete Git</a>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Ana Sayfaya Don</a>
            </div>
        </div>
    </div>
</section>
