@model Web.HMD.Models.ReceiverTypeViewModel

@{
    ViewData["Title"] = $"{Model.Code} Receiver Detayi";
}

<section class="receiver-section py-3">
    <div class="section-head">
        <h2 class="text-white">@Model.Code Receiver Ozellikleri</h2>
        <p class="text-white-50">Teknik degerler paylastigin tabloya gore guncellenmistir.</p>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-3 d-flex flex-wrap gap-2 align-items-center justify-content-between bg-dark">
            <span class="fw-semibold text-white">Teknik Bilgiler</span>
            <span class="badge bg-info text-dark rounded-pill">$@Model.Price</span>
        </div>
        <div class="table-responsive mainboard-table-wrap">
            <table class="table table-sm table-hover table-striped table-bordered align-middle mb-0 mainboard-table">
                <tbody>
                    <tr><th>Model</th><td>@Model.Code</td></tr>
                    <tr><th>Interface</th><td>@Model.Interface</td></tr>
                    <tr><th>Ports</th><td>@Model.Ports</td></tr>
                    <tr><th>Calibration Accuracy</th><td>@Model.CalibrationAccuracy</td></tr>
                    <tr><th>PWM Capacity</th><td>@Model.PwmCapacity</td></tr>
                    <tr><th>Normal Capacity</th><td>@Model.NormalCapacity</td></tr>
                    <tr><th>LS Capacity</th><td>@Model.LsCapacity</td></tr>
                    <tr><th>Remark</th><td>@Model.Remark</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <form asp-controller="Products" asp-action="AddReceiverToCart" method="post">
            <input type="hidden" name="code" value="@Model.Code" />
            <button type="submit" class="btn btn-primary premium-btn">Sepete Ekle</button>
        </form>
        <a asp-controller="Home" asp-action="CartStatus" class="btn btn-outline-light">Sepete Git</a>
        <a asp-controller="Products" asp-action="Receivers" class="btn btn-outline-secondary">Receiver Listesi</a>
    </div>
</section>
