@model Web.HMD.Models.PanelTypeViewModel

@{
    ViewData["Title"] = $"{Model.Code} Panel Detayi";
}

<section class="receiver-section py-3">
    <div class="section-head">
        <h2 class="text-white">@Model.Code Panel Ozellikleri</h2>
        <p class="text-white-50">@Model.Description</p>
    </div>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-2 px-3 d-flex flex-wrap gap-2 align-items-center justify-content-between bg-dark">
            <span class="fw-semibold text-white">Teknik Bilgiler</span>
            <span class="badge bg-info text-dark rounded-pill">$@Model.Price</span>
        </div>
        <div class="table-responsive mainboard-table-wrap">
            <table class="table table-sm table-hover table-striped table-bordered align-middle mb-0 mainboard-table">
                <tbody>
                    <tr>
                        <th class="text-nowrap">Panel Tipi</th>
                        <td>@Model.Code</td>
                    </tr>
                    <tr>
                        <th class="text-nowrap">Pixel Pitch</th>
                        <td>@Model.PixelPitch</td>
                    </tr>
                    <tr>
                        <th class="text-nowrap">Onerilen Kullanim</th>
                        <td>@Model.RecommendedUse</td>
                    </tr>
                    <tr>
                        <th class="text-nowrap">Minimum Izleme Mesafesi</th>
                        <td>@Model.MinViewingDistance</td>
                    </tr>
                    <tr>
                        <th class="text-nowrap">Refresh Rate</th>
                        <td>@Model.RefreshRate</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <form asp-controller="Products" asp-action="AddPanelToCart" method="post">
            <input type="hidden" name="code" value="@Model.Code" />
            <button type="submit" class="btn btn-primary premium-btn">Sepete Ekle</button>
        </form>
        <a asp-controller="Home" asp-action="CartStatus" class="btn btn-outline-light">Sepete Git</a>
        <a asp-controller="Products" asp-action="PanelTypes" class="btn btn-outline-secondary">Panel Listesi</a>
    </div>
</section>
