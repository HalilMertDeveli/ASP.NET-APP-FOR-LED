@model IEnumerable<Web.HMD.Models.PanelTypeViewModel>

@{
    ViewData["Title"] = "Panel Turleri";
}

<section class="py-3">
    <div class="mb-4">
        <h1 class="h3 fw-bold">Panel Turleri</h1>
        <p class="text-muted mb-0">Asagidaki 8 panel tipinin her biri ayri sayfaya gider, teknik ozelliklerini gosterir ve sepete eklenebilir.</p>
    </div>

    <div class="row g-3">
        @foreach (var panel in Model)
        {
            <div class="col-6 col-md-4 col-lg-3">
                <a asp-controller="Products" asp-action="@panel.RouteAction" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 panel-type-card">
                    <div class="card-body">
                        <h5 class="mb-1 text-dark">@panel.Code</h5>
                        <p class="small text-secondary mb-1">@panel.Description</p>
                        <p class="small mb-0 text-primary fw-semibold">Detay + Sepete Ekle</p>
                    </div>
                </div>
                </a>
            </div>
        }
    </div>
</section>
