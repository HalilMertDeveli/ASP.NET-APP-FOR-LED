@model Web.HMD.Models.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('mousemove', (e) => {
            const orbs = document.querySelectorAll('.bg-orb');
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            
            orbs.forEach((orb, index) => {
                const speed = (index + 1) * 30;
                const xOffset = (x - 0.5) * speed;
                const yOffset = (y - 0.5) * speed;
                orb.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
            });
        });
    </script>
}

<div class="dynamic-bg-container circuit-pattern">
    <div class="bg-orb orb-1 neon-glow"></div>
    <div class="bg-orb orb-2 neon-glow"></div>
    <div class="bg-orb orb-3 neon-glow"></div>
</div>

<div class="row align-items-center auth-container vh-100 mt-negative flex-row-reverse">
    <div class="col-md-6 d-none d-md-block h-100 p-0 position-relative" style="background: url('https://images.unsplash.com/photo-1542831371-29b0f74f9713?w=1200&q=80') center/cover no-repeat;">
        <div class="auth-overlay d-flex align-items-center justify-content-center flex-column text-white p-5">
            <div class="bg-white bg-opacity-10 p-4 rounded-circle mb-4 backdrop-blur shadow-lg border border-white border-opacity-20 animation-slide-up">
                <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" fill="currentColor" class="bi bi-cpu text-info" viewBox="0 0 16 16">
                  <path d="M5 0a.5.5 0 0 1 .5.5V2h1V.5a.5.5 0 0 1 1 0V2h1V.5a.5.5 0 0 1 1 0V2h1V.5a.5.5 0 0 1 1 0V2h.5a.5.5 0 0 1 .5.5v1h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14v1h1.5a.5.5 0 0 1 0 1H14v1h.5a.5.5 0 0 1 .5.5v1h-1.5a.5.5 0 0 1 0-1H14v-1h-1.5a.5.5 0 0 1 0-1H14v-1h-1.5a.5.5 0 0 1 0-1H14v-1h-1.5a.5.5 0 0 1 0-1H14v-1h-1.5a.5.5 0 0 1 0-1H14v-1h.5a.5.5 0 0 1-.5-.5v-1h1.5a.5.5 0 0 1 0-1H14V2h-1.5a.5.5 0 0 1 0-1H11.5a.5.5 0 0 1-.5-.5V0H10v1.5a.5.5 0 0 1-1 0V0H8v1.5a.5.5 0 0 1-1 0V0H6v1.5a.5.5 0 0 1-1 0V0H5zM13 13H3V3h10v10zM5.5 4a.5.5 0 0 0-.5.5v7a.5.5 0 0 0 .5.5h5a.5.5 0 0 0 .5-.5v-7a.5.5 0 0 0-.5-.5h-5z"/>
                </svg>
            </div>
            <h2 class="display-5 fw-bold mb-3 animation-slide-up">Elektronik Dünyasına Adım Atın</h2>
            <p class="lead text-center animation-slide-up-delay">HMD LED Servis ile cihazlarınızı geleceğin teknolojisiyle yenileyin. En kaliteli onarım ve parçalara bir tık uzaktasınız.</p>
        </div>
    </div>
    <div class="col-md-6 pb-5 pb-md-0 position-relative">
        <div class="card border-0 glass-card-premium mx-auto shadow-lg animation-fade-in p-2">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-5">
                    <div class="d-inline-flex align-items-center justify-content-center led-icon-container p-3 rounded-4 mb-3 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="currentColor" class="bi bi-patch-question-fill" viewBox="0 0 16 16">
                          <path d="M5.933.87a2.89 2.89 0 0 1 4.134 0l.622.638.89-.011a2.89 2.89 0 0 1 2.924 2.924l-.01.89.636.622a2.89 2.89 0 0 1 0 4.134l-.637.622.011.89a2.89 2.89 0 0 1-2.924 2.924l-.89-.01-.622.636a2.89 2.89 0 0 1-4.134 0l-.622-.637-.89.011a2.89 2.89 0 0 1-2.924-2.924l.01-.89-.636-.622a2.89 2.89 0 0 1 0-4.134l.637-.622-.011-.89a2.89 2.89 0 0 1 2.924-2.924l.89.01.622-.636zM7.002 11a1 1 0 1 0 2 0 1 1 0 0 0-2 0zm1.602-2.027c.04-.534.198-.815.846-1.26.674-.475.81-.74.81-.969 0-.642-.447-1.02-1.209-1.02-.73 0-1.21.43-1.243 1.177H6.655C6.692 5.644 7.325 5 8.25 5c1.026 0 1.83.65 1.83 1.637 0 .61-.312.986-1.112 1.543-.538.384-.666.52-.733.92H8.604z"/>
                        </svg>
                    </div>
                    <h3 class="fw-bolder">Yeni Hesap Oluştur</h3>
                    <p class="text-muted">LED dünyasına özel avantajlardan hemen faydalanın.</p>
                </div>
                
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-weight-bold"></div>

                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="FullName" type="text" class="form-control auth-input led-input" id="floatingName" placeholder="Adınız Soyadınız" required autocomplete="off">
                        <label for="floatingName">Tam Adınız</label>
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block text-start"></span>
                    </div>

                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="Email" type="email" class="form-control auth-input led-input" id="floatingEmail" placeholder="ornek@mail.com" required autocomplete="off">
                        <label for="floatingEmail">E-Posta Adresiniz</label>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block text-start"></span>
                    </div>
                    
                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="Phone" type="tel" class="form-control auth-input led-input" id="floatingPhone" placeholder="0555..." autocomplete="off">
                        <label for="floatingPhone">Telefon Numarası</label>
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block text-start"></span>
                    </div>

                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="Password" type="password" class="form-control auth-input led-input" id="floatingRegPass" placeholder="Şifreniz" required autocomplete="new-password">
                        <label for="floatingRegPass">Giriş Şifresi</label>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block text-start"></span>
                    </div>
                    
                    <button class="btn btn-primary neon-btn w-100 py-3 mb-4 d-flex align-items-center justify-content-center gap-2" type="submit">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" class="bi bi-lightning-charge-fill" viewBox="0 0 16 16">
                          <path d="M11.251.068a.5.5 0 0 1 .227.58L9.677 6.5H13a.5.5 0 0 1 .364.843l-8 8.5a.5.5 0 0 1-.842-.49L6.323 9.5H3a.5.5 0 0 1-.364-.843l8-8.5a.5.5 0 0 1 .615-.09z"/>
                        </svg>
                        Kayıt İşlemini Başlat
                    </button>
                </form>

                <div class="text-center text-muted mb-3 d-flex align-items-center gap-2">
                    <hr class="flex-grow-1"> veya <hr class="flex-grow-1">
                </div>
                <div class="row g-2 mb-4">
                    <div class="col-6">
                        <form asp-action="ExternalLogin" method="post">
                            <input type="hidden" name="provider" value="Google" />
                            <button type="submit" class="btn btn-light w-100 py-3 d-flex align-items-center justify-content-center gap-2 border shadow-sm">
                                <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M17.64 9.2045c0-.6382-.0573-1.2518-.1636-1.8409H9v3.4818h4.8436c-.2086 1.125-.8427 2.0782-1.7959 2.7164v2.2582h2.9086c1.7023-1.5673 2.6837-3.8773 2.6837-6.6155z" fill="#4285F4"/>
                                    <path d="M9 18c2.43 0 4.4673-.8059 5.9564-2.1791l-2.9086-2.2582c-.806.54-1.8368.8591-3.0478.8591-2.3427 0-4.3282-1.5823-5.0368-3.7082H.9573v2.3291C2.4382 15.9832 5.4818 18 9 18z" fill="#34A853"/>
                                    <path d="M3.9632 10.7136C3.7832 10.1736 3.6818 9.5968 3.6818 9s.1014-1.1736.2814-1.7136V4.9573H.9573C.3477 6.1732 0 7.5491 0 9s.3477 2.8268.9573 4.0427l3.0059-2.3291z" fill="#FBBC05"/>
                                    <path d="M9 3.5782c1.3214 0 2.5077.4541 3.4418 1.3459l2.5814-2.5814C13.4632.8918 11.43 0 9 0 5.4818 0 2.4382 2.0168.9573 4.9573l3.0059 2.3291C4.6718 5.1605 6.6573 3.5782 9 3.5782z" fill="#EA4335"/>
                                </svg>
                                Google
                            </button>
                        </form>
                    </div>
                    <div class="col-6">
                        <form asp-action="ExternalLogin" method="post">
                            <input type="hidden" name="provider" value="Facebook" />
                            <button type="submit" class="btn btn-light w-100 py-3 d-flex align-items-center justify-content-center gap-2 border shadow-sm">
                                <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                    <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.024 4.388 11.017 10.125 11.927v-8.437H7.078v-3.49h3.047V9.41c0-3.022 1.792-4.69 4.533-4.69 1.313 0 2.686.236 2.686.236v2.97h-1.514c-1.492 0-1.956.93-1.956 1.885v2.262h3.328l-.532 3.49h-2.796V24C19.612 23.09 24 18.097 24 12.073z" fill="#1877F2"/>
                                </svg>
                                Facebook
                            </button>
                        </form>
                    </div>
                </div>

                <p class="text-center text-muted mb-0 small">Zaten bir hesabınız var mı? <a asp-controller="Account" asp-action="Login" class="text-info text-decoration-none fw-bold">Giriş Yapın</a></p>
            </div>
        </div>
    </div>
</div>
