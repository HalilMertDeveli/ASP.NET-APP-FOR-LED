@model Web.HMD.Models.RegisterViewModel

@{
    ViewData["Title"] = "Kayıt Ol";
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('mousemove', (e) => {
            const orbs = document.querySelectorAll('.bg-orb');
            const x = e.clientX / window.innerWidth;
            const y = e.clientY / window.innerHeight;
            
            orbs.forEach((orb, index) => {
                const speed = (index + 1) * 20;
                const xOffset = (x - 0.5) * speed;
                const yOffset = (y - 0.5) * speed;
                orb.style.transform = `translate(${xOffset}px, ${yOffset}px)`;
            });
        });
    </script>
}

<div class="dynamic-bg-container">
    <div class="bg-orb orb-1"></div>
    <div class="bg-orb orb-2"></div>
    <div class="bg-orb orb-3"></div>
</div>

<div class="row align-items-center auth-container vh-100 mt-negative flex-row-reverse">
    <div class="col-md-6 d-none d-md-block h-100 p-0 position-relative auth-bg-register">
        <div class="auth-overlay d-flex align-items-center justify-content-center flex-column text-white p-5">
            <h2 class="display-5 fw-bold mb-3 animation-slide-up">Aramıza Katılın</h2>
            <p class="lead animation-slide-up-delay">Hemen hesabınızı oluşturun ve profesyonel LED onarım hizmetlerimizden faydalanın.</p>
        </div>
    </div>
    <div class="col-md-6 pb-5 pb-md-0 position-relative">
        <div class="card border-0 auth-form-card mx-auto shadow-lg animation-fade-in">
            <div class="card-body p-5">
                <div class="text-center mb-5">
                    <h3 class="fw-bolder">Yeni Hesap Oluştur</h3>
                    <p class="text-muted">Aşağıdaki formu doldurarak kayıt işlemlerini tamamlayın.</p>
                </div>
                
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3 font-weight-bold"></div>

                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="FullName" type="text" class="form-control auth-input" id="floatingName" placeholder="Adınız Soyadınız" required autocomplete="off">
                        <label for="floatingName">İsim ve Soyisim</label>
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block text-start"></span>
                    </div>

                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="Email" type="email" class="form-control auth-input" id="floatingEmail" placeholder="ornek@mail.com" required autocomplete="off">
                        <label for="floatingEmail">E-Posta Adresiniz</label>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block text-start"></span>
                    </div>
                    
                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="Phone" type="tel" class="form-control auth-input" id="floatingPhone" placeholder="0555..." autocomplete="off">
                        <label for="floatingPhone">Telefon Numaranız</label>
                        <span asp-validation-for="Phone" class="text-danger small mt-1 d-block text-start"></span>
                    </div>

                    <div class="form-floating mb-4 form-group-animated">
                        <input asp-for="Password" type="password" class="form-control auth-input" id="floatingRegPass" placeholder="Şifreniz" required autocomplete="new-password">
                        <label for="floatingRegPass">Şifreniz</label>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block text-start"></span>
                    </div>
                    
                    <button class="btn btn-primary auth-submit-btn w-100 py-3 mb-4" type="submit">Kayıt Ol</button>
                </form>

                <div class="text-center text-muted mb-3">veya</div>
                <form asp-action="ExternalLogin" method="post" class="mb-3">
                    <input type="hidden" name="provider" value="Google" />
                    <button type="submit" class="btn btn-outline-dark w-100 py-3 d-flex align-items-center justify-content-center gap-2">
                        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M17.64 9.2045c0-.6382-.0573-1.2518-.1636-1.8409H9v3.4818h4.8436c-.2086 1.125-.8427 2.0782-1.7959 2.7164v2.2582h2.9086c1.7023-1.5673 2.6837-3.8773 2.6837-6.6155z" fill="#4285F4"/>
                            <path d="M9 18c2.43 0 4.4673-.8059 5.9564-2.1791l-2.9086-2.2582c-.806.54-1.8368.8591-3.0478.8591-2.3427 0-4.3282-1.5823-5.0368-3.7082H.9573v2.3291C2.4382 15.9832 5.4818 18 9 18z" fill="#34A853"/>
                            <path d="M3.9632 10.7136C3.7832 10.1736 3.6818 9.5968 3.6818 9s.1014-1.1736.2814-1.7136V4.9573H.9573C.3477 6.1732 0 7.5491 0 9s.3477 2.8268.9573 4.0427l3.0059-2.3291z" fill="#FBBC05"/>
                            <path d="M9 3.5782c1.3214 0 2.5077.4541 3.4418 1.3459l2.5814-2.5814C13.4632.8918 11.43 0 9 0 5.4818 0 2.4382 2.0168.9573 4.9573l3.0059 2.3291C4.6718 5.1605 6.6573 3.5782 9 3.5782z" fill="#EA4335"/>
                        </svg>
                        Google ile Devam Et
                    </button>
                </form>

                <form asp-action="ExternalLogin" method="post" class="mb-4">
                    <input type="hidden" name="provider" value="Facebook" />
                    <button type="submit" class="btn btn-outline-primary w-100 py-3 d-flex align-items-center justify-content-center gap-2">
                        <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073c0 6.024 4.388 11.017 10.125 11.927v-8.437H7.078v-3.49h3.047V9.41c0-3.022 1.792-4.69 4.533-4.69 1.313 0 2.686.236 2.686.236v2.97h-1.514c-1.492 0-1.956.93-1.956 1.885v2.262h3.328l-.532 3.49h-2.796V24C19.612 23.09 24 18.097 24 12.073z" fill="#1877F2"/>
                        </svg>
                        Facebook ile Devam Et
                    </button>
                </form>

                <p class="text-center text-muted mb-0">Zaten bir hesabınız var mı? <a asp-controller="Account" asp-action="Login" class="text-decoration-none fw-bold redirect-link">Giriş Yapın</a></p>
            </div>
        </div>
    </div>
</div>
