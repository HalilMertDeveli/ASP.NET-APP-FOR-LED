<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - LED Service Pro</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
</head>
<body class="auth-body led-animated-bg">
    <div class="led-site-bg" aria-hidden="true">
        <div class="global-led-bg" id="globalLedBg"></div>
        <span class="led-site-orb led-site-orb-1"></span>
        <span class="led-site-orb led-site-orb-2"></span>
        <span class="led-site-orb led-site-orb-3"></span>
        <span class="led-site-scanline"></span>
    </div>
    <main class="auth-shell">
        @RenderBody()
    </main>

    <partial name="_LiveSupportWidget" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
