@using System.Text.Json
@{
    var cartCount = 0;
    var cartJson = Context.Session.GetString("CartItems");
    if (!string.IsNullOrWhiteSpace(cartJson))
    {
        var cartItems = JsonSerializer.Deserialize<List<Web.HMD.Models.LedRepairViewModel>>(cartJson) ?? new List<Web.HMD.Models.LedRepairViewModel>();
        cartCount = cartItems.Count;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web.HMD</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web.HMD.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm led-main-navbar mb-3">
            <div class="container-fluid">
                <a class="navbar-brand led-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="led-brand-dot"></span> LED Service Pro
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Servisler</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Home" asp-action="CartStatus">
                                Sepet Durumu <span class="badge text-bg-light ms-1">@cartCount</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Support" asp-action="Upload">Dosya Yukle</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-light-emphasis pe-3 border-end">Profil: <strong class="text-light">@(User?.Identity?.Name ?? "Kullanici")</strong></span>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="nav-link led-nav-link fw-bold" asp-area="" asp-controller="Account" asp-action="Settings">Ayarlar</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-outline-danger shadow-sm fw-bold" asp-area="" asp-controller="Account" asp-action="Logout">Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link led-nav-link fw-bold" asp-area="" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary premium-btn text-white" asp-area="" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer led-main-footer">
        <div class="container py-4">
            <div class="row g-3 align-items-center">
                <div class="col-md-6">
                    <h6 class="mb-1 text-light">LED Service Pro</h6>
                    <p class="mb-0 small">Profesyonel LED ekran bakim, onarim ve operasyon yonetim platformu.</p>
                </div>
                <div class="col-md-6 d-flex justify-content-md-end gap-3 small">
                    <a asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                    <a asp-area="" asp-controller="Home" asp-action="Privacy">Gizlilik</a>
                    <a asp-area="" asp-controller="Account" asp-action="Login">Giris</a>
                </div>
            </div>
            <div class="border-top border-secondary-subtle mt-3 pt-3 small text-secondary">
                &copy; 2026 LED Service Pro. Tum haklari saklidir.
            </div>
        </div>
    </footer>
    <partial name="_LiveSupportWidget" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
