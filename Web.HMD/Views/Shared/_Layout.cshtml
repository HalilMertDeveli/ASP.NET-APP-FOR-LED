@using System.Text.Json
@{
    var cartCount = 0;
    var cartJson = Context.Session.GetString("CartItems");
    if (!string.IsNullOrWhiteSpace(cartJson))
    {
        var cartItems = JsonSerializer.Deserialize<List<Web.HMD.Models.LedRepairViewModel>>(cartJson) ?? new List<Web.HMD.Models.LedRepairViewModel>();
        cartCount = cartItems.Count;
    }
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Web.HMD</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/chatbot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Web.HMD.styles.css" asp-append-version="true" />
</head>
<body class="led-animated-bg">
    <div class="led-site-bg" aria-hidden="true">
        <div class="global-led-bg" id="globalLedBg"></div>
        <span class="led-site-orb led-site-orb-1"></span>
        <span class="led-site-orb led-site-orb-2"></span>
        <span class="led-site-orb led-site-orb-3"></span>
        <span class="led-site-scanline"></span>
    </div>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm led-main-navbar mb-3">
            <div class="container-fluid">
                <button class="btn led-sidebar-trigger me-2" type="button" data-bs-toggle="offcanvas" data-bs-target="#siteSidebar" aria-controls="siteSidebar">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <a class="navbar-brand led-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <span class="led-brand-logo" aria-hidden="true">HMD</span>
                    <span class="led-brand-text">LED Service Pro</span>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Servisler</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle led-nav-link" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Kategoriler
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="PanelTypes">Paneller</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Receivers">Receiver'lar</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="PowerSupplies">Guc Saglayicilar</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Motherboards">Ana Kartlar (A Serisi)</a></li>
                            </ul>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link led-nav-link" asp-area="" asp-controller="Home" asp-action="CartStatus">
                                Sepet Durumu <span class="badge text-bg-light ms-1">@cartCount</span>
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item d-flex align-items-center">
                                <span class="nav-link text-light-emphasis pe-3 border-end">Profil: <strong class="text-light">@(User?.Identity?.Name ?? "Kullanici")</strong></span>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="nav-link led-nav-link fw-bold" asp-area="" asp-controller="Account" asp-action="Settings">Ayarlar</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-outline-danger shadow-sm fw-bold" asp-area="" asp-controller="Account" asp-action="Logout">Çıkış Yap</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link led-nav-link fw-bold" asp-area="" asp-controller="Account" asp-action="Login">Giriş Yap</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary premium-btn text-white" asp-area="" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="offcanvas offcanvas-start led-offcanvas" tabindex="-1" id="siteSidebar" aria-labelledby="siteSidebarLabel">
        <div class="offcanvas-header border-bottom border-secondary-subtle">
            <h5 class="offcanvas-title d-flex align-items-center gap-2" id="siteSidebarLabel">
                <span class="led-brand-dot"></span> Site Menusu
            </h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body d-flex flex-column">
            <div class="mb-3">
                <a class="led-side-link" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                <a class="led-side-link" asp-controller="Home" asp-action="Privacy">Servisler</a>
                <a class="led-side-link" asp-controller="Home" asp-action="CartStatus">Sepet Durumu (@cartCount)</a>
                <a class="led-side-link" asp-controller="Products" asp-action="PanelTypes">Kategori: Paneller</a>
                <a class="led-side-link" asp-controller="Products" asp-action="Receivers">Kategori: Receiver'lar</a>
                <a class="led-side-link" asp-controller="Products" asp-action="PowerSupplies">Kategori: Guc Saglayicilar</a>
                <a class="led-side-link" asp-controller="Products" asp-action="Motherboards">Kategori: Ana Kartlar (A Serisi)</a>
            </div>

            <div class="led-side-box mt-2">
                <h6 class="mb-2">Site Ozellikleri</h6>
                <ul class="small mb-0 ps-3">
                    <li>Canli destek ile hizli teknik yonlendirme</li>
                    <li>Panel dosya import ve merkezi SQL kayit</li>
                    <li>P + Chipset + Decoder bazli otomatik dosya bulma</li>
                    <li>Modern dashboard ve sepet yonetimi</li>
                </ul>
            </div>

            <div class="mt-auto pt-3 small text-secondary">
                LED Service Pro - Profesyonel operasyon paneli
            </div>
        </div>
    </div>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer led-main-footer mt-4">
        <div class="container py-4 py-md-5">
            <div class="row g-4">
                <div class="col-md-4">
                    <h6 class="mb-2 text-light">LED Service Pro</h6>
                    <p class="small mb-2">Profesyonel LED ekran bakim, onarim ve operasyon yonetim platformu.</p>
                    <p class="small mb-0 text-secondary">Canli destek, hizli dosya erisimi ve guvenli teknik operasyon yonetimi.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="mb-2 text-light">Hizli Linkler</h6>
                    <div class="d-grid gap-1 small">
                        <a asp-area="" asp-controller="Home" asp-action="Index">Ana Sayfa</a>
                        <a asp-area="" asp-controller="Home" asp-action="Privacy">Servisler</a>
                        <a asp-area="" asp-controller="Home" asp-action="CartStatus">Sepet Durumu</a>
                        <a asp-area="" asp-controller="Account" asp-action="Login">Giris Yap</a>
                    </div>
                </div>
                <div class="col-md-4">
                    <h6 class="mb-2 text-light">Iletisim</h6>
                    <div class="small d-grid gap-1">
                        <span>Telefon: +90 546 912 48 45</span>
                        <span>E-Posta: destek@ledservicepro.com</span>
                        <span>Adres: Istanbul / Turkiye</span>
                        <span>Calisma Saatleri: 09:00 - 18:00</span>
                    </div>
                </div>
            </div>
            <div class="border-top border-secondary-subtle mt-4 pt-3 d-flex flex-wrap justify-content-between gap-2 small text-secondary">
                <span>&copy; 2026 LED Service Pro. Tum haklari saklidir.</span>
                <span>Kullanim Sartlari | Gizlilik Politikasi</span>
            </div>
        </div>
    </footer>
    <partial name="_LiveSupportWidget" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
