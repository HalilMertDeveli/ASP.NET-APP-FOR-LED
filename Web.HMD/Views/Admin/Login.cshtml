@{
    ViewData["Title"] = "Admin Giris";
}

<section class="container py-5 admin-login-page" style="max-width: 760px;">
    <div class="row g-4 align-items-center">
        <div class="col-md-6">
            <h2 class="fw-bold mb-2 text-white">Admin Arayuz Girisi</h2>
            <p class="text-white-50 mb-0">Yonetim paneline gecip dosya, destek ve sistem islemlerini yonetin.</p>
        </div>
        <div class="col-md-6">
            <div class="card shadow border-0 bg-dark text-white">
                <div class="card-header admin-login-header">
                    <h4 class="mb-0">Admin Giris</h4>
                </div>
                <div class="card-body">
                    @if (TempData["AdminLoginError"] != null)
                    {
                        <div class="alert alert-danger app-toast-center">@TempData["AdminLoginError"]</div>
                    }

                    <form asp-controller="Admin" asp-action="Login" method="post" class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold text-white">Kullanici Adi</label>
                            <input name="username" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold text-white">Sifre</label>
                            <input name="password" type="password" class="form-control" required />
                        </div>
                        <div class="col-12 d-grid gap-2">
                            <button type="submit" class="btn btn-primary w-100">Giris Yap</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Ana Sayfaya Don</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .admin-login-page {
        background: linear-gradient(180deg, #020617 0%, #0f172a 100%);
        border-radius: 16px;
        padding-left: 1rem;
        padding-right: 1rem;
    }

    .admin-login-header {
        background: linear-gradient(135deg, #1d4ed8, #2563eb);
        color: #f8fafc;
    }

    .admin-login-page .form-control {
        border: 1px solid rgba(148, 163, 184, 0.45);
        color: #f8fafc;
        background-color: rgba(15, 23, 42, 0.9);
    }

    .admin-login-page .form-control:focus {
        border-color: #60a5fa;
        box-shadow: 0 0 0 0.2rem rgba(96, 165, 250, 0.22);
    }

    .admin-login-page .form-control::placeholder {
        color: #94a3b8;
    }
</style>
