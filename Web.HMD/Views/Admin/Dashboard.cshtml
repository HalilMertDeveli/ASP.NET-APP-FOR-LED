@{
    ViewData["Title"] = "Admin Panel";
}

<section class="container py-4 admin-dashboard-page">
    <div class="p-4 p-md-5 rounded-4 text-white mb-4" style="background: linear-gradient(135deg, #0f172a, #1d4ed8);">
        <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
            <div>
                <h1 class="h3 mb-2">Admin Kontrol Paneli</h1>
                <p class="mb-0 text-light-emphasis">Sistem islemlerini tek ekrandan yonetin, dosya ve destek sureclerini hizlandirin.</p>
            </div>
            <form asp-controller="Admin" asp-action="Logout" method="post" class="m-0">
                <button type="submit" class="btn btn-outline-light">Guvenli Cikis</button>
            </form>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 bg-dark text-white">
                <div class="card-body">
                    <h5>Dosya Yonetimi</h5>
                    <p class="text-white-50">Panel dosyalarini manuel yukleyin veya kutuphaneden toplu import edin.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-controller="Support" asp-action="Upload" class="btn btn-primary">Dosya Islem Ekrani</a>
                        <a asp-controller="Support" asp-action="ScanUpload" class="btn btn-outline-primary">Tarama Dosyasi Yukle</a>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 bg-dark text-white">
                <div class="card-body">
                    <h5>Canli Destek</h5>
                    <p class="text-white-50">Kullanicilarin chatbot ve temsilci taleplerini izleyin.</p>
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Canli Destek Gorunumu</a>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100 bg-dark text-white">
                <div class="card-body">
                    <h5>Kullanici Girisleri</h5>
                    <p class="text-white-50">Kullanici giris/kayit deneyimini test etmek icin hizli gecis.</p>
                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Kullanici Girisi</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-outline-light btn-sm">Kayit Ekrani</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .admin-dashboard-page {
        background: linear-gradient(180deg, #020617 0%, #0f172a 100%);
        border-radius: 16px;
    }
</style>
